{
  "name": "OpenReqHeader",
  "version": "4.0.0",
  "manifest_version": 3,
  "description": "Modify HTTP request and response headers",
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "images/icon_16.png",
      "48": "images/icon_48.png",
      "128": "images/icon_128.png"
    },
    "default_title": "OpenReqHeader",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon_16.png",
    "48": "images/icon_48.png",
    "128": "images/icon_128.png"
  },
  "incognito": "spanning",
  "permissions": ["contextMenus", "storage", "webRequest", "declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+H"
      }
    },
    "toggle_pause": {
      "description": "Toggle pause/resume",
      "suggested_key": {
        "default": "Alt+Shift+P"
      }
    },
    "toggle_lock": {
      "description": "Toggle lock tab"
    },
    "switch_to_profile_1": {
      "description": "Switch to 1st profile"
    },
    "switch_to_profile_2": {
      "description": "Switch to 2nd profile"
    },
    "switch_to_profile_3": {
      "description": "Switch to 3rd profile"
    },
    "switch_to_profile_4": {
      "description": "Switch to 4th profile"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["images/icon_bw.png", "app.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
